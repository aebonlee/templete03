# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요. (.env.local 은 git 제외)

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 사이트
VITE_SITE_URL=https://templete03.dreamitbiz.com

# 테이블 접두사 — 프로젝트별로 변경 (예: rest_, snu_, ax_)
VITE_TABLE_PREFIX=tpl_

# 포트원(아임포트) 결제
VITE_IMP_CODE=imp00000000
VITE_PG_PROVIDER=html5_inicis.YourMID

# Supabase 관리 토큰 — CLI 전용 (VITE_ 접두사 절대 금지)
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx
